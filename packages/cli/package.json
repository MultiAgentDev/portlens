{
  "name": "@portlens/cli",
  "version": "1.0.0",
  "description": "Share your local server with anyone, instantly.",
  "type": "module",
  "bin": {
    "portlens": "/dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@portlens/shared": "^0.0.0",
    "chalk": "^4.1.2",
    "commander": "^8.3.0",
    "dotenv": "^10.0.0",
    "open": "^8.4.2",
    "ora": "^9.4.0",
    "puppeteer-core": "^25.0.2",
    "qrcode-terminal": "^0.12.0",
    "ws": "^7.5.10"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.2",
    "typescript": "*"
  }
}